<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>투자비 감가상각(회수) 계산기</title>

  <style>
    :root{
      --bg:#f8fafc;
      --card:#ffffff;
      --border:#e2e8f0;
      --text:#0f172a;
      --muted:#64748b;
      --good-bg:#ecfdf5;
      --good-border:#a7f3d0;
      --bad-bg:#fff1f2;
      --bad-border:#fecdd3;
      --warn-bg:#fffbeb;
      --warn-border:#fcd34d;
      --shadow:0 1px 2px rgba(15,23,42,.06);
      --radius:18px;
    }
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family: ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, "Noto Sans KR", Arial, "Apple SD Gothic Neo", "Malgun Gothic", sans-serif;
      background:var(--bg);
      color:var(--text);
    }
    .wrap{max-width:1100px;margin:0 auto;padding:16px}
    @media (min-width:768px){ .wrap{padding:32px} }

    .header{display:flex;flex-direction:column;gap:8px;}
    @media (min-width:768px){
      .header{flex-direction:row;align-items:flex-end;justify-content:space-between}
    }
    h1{margin:0;font-size:26px;letter-spacing:-.02em}
    .sub{margin:6px 0 0;color:var(--muted);font-size:13px}

    .maker{
      font-size:11px;
      color:var(--muted);
      text-align:right;
      line-height:1.2;
      white-space:nowrap;
    }

    .btn{
      appearance:none;border:1px solid var(--border);background:#fff;
      padding:10px 14px;border-radius:999px;cursor:pointer;
      display:inline-flex;gap:8px;align-items:center;
      box-shadow:var(--shadow);
      font-size:13px;
    }
    .btn:hover{background:#f1f5f9}
    .btn[disabled]{opacity:.6;cursor:not-allowed}

    .pill{
      display:inline-flex;align-items:center;border:1px solid var(--border);
      padding:6px 10px;border-radius:999px;font-size:12px;color:#0f172a;background:#fff
    }

    .card{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:var(--radius);
      box-shadow:var(--shadow);
    }
    .card-h{padding:14px 16px}
    .card-t{margin:0;font-size:14px}
    .card-c{padding:16px}

    .grid-main{display:grid;grid-template-columns:1fr;gap:16px;margin-top:16px}
    @media (min-width:1024px){
      .grid-main{grid-template-columns:1fr 2fr}
    }

    label{display:block;font-size:12px;color:#0f172a;margin-bottom:6px}
    input{
      width:100%;padding:10px 12px;border-radius:14px;border:1px solid var(--border);
      font-size:14px;outline:none;background:#fff;
    }
    input:focus{border-color:#94a3b8;box-shadow:0 0 0 3px rgba(148,163,184,.25)}
    .help{font-size:11px;color:var(--muted);margin-top:6px}

    .row2{display:grid;grid-template-columns:1fr;gap:12px}
    @media (min-width:540px){ .row2{grid-template-columns:1fr 1fr} }

    .adv-toggle{
      width:100%;
      display:flex;justify-content:space-between;align-items:center;
      border:1px solid var(--border);background:#fff;
      padding:10px 12px;border-radius:var(--radius);
      cursor:pointer;font-size:13px;
    }
    .adv{margin-top:12px;display:none}
    .adv.show{display:block}

    .warn{
      background:var(--warn-bg);
      border:1px solid var(--warn-border);
      border-radius:var(--radius);
      padding:12px 14px;
      margin-top:12px;
    }
    .warn strong{display:block;margin-bottom:6px}
    .warn ul{margin:0;padding-left:18px;color:#7c2d12;font-size:12px;line-height:1.4}

    .kpis{display:grid;grid-template-columns:1fr;gap:12px}
    @media (min-width:768px){ .kpis{grid-template-columns:repeat(4,1fr)} }

    .kpi{
      border:1px solid var(--border);
      border-radius:var(--radius);
      padding:14px;
      background:#fff;
    }
    .kpi.good{background:var(--good-bg);border-color:var(--good-border)}
    .kpi.bad{background:var(--bad-bg);border-color:var(--bad-border)}
    .kpi .t{font-size:11px;color:var(--muted)}
    .kpi .v{font-size:18px;font-weight:700;margin-top:6px}
    .kpi .s{font-size:11px;color:var(--muted);margin-top:6px;line-height:1.3}

    .summary-box{
      margin-top:12px;
      border:1px solid var(--border);
      border-radius:var(--radius);
      background:#fff;
      padding:14px;
      display:flex;flex-direction:column;gap:10px
    }
    .summary-line{font-size:13px;color:#0f172a}
    .muted{color:var(--muted)}
    .chart-wrap{
      margin-top:12px;
      border:1px solid var(--border);
      border-radius:var(--radius);
      background:#fff;
      padding:12px;
      height:280px;
    }

    .table-card{margin-top:16px}
    .table-wrap{
      overflow:auto;border:1px solid var(--border);
      border-radius:var(--radius);background:#fff;
    }
    table{border-collapse:collapse;min-width:980px;width:100%}
    thead th{
      background:#f1f5f9;
      text-align:left;
      font-size:12px;
      padding:10px 12px;
      border-bottom:1px solid var(--border);
      white-space:nowrap;
    }
    tbody td{
      font-size:12px;
      padding:10px 12px;
      border-top:1px solid var(--border);
      white-space:nowrap;
    }
    .pos{color:#047857;font-weight:600}
    .neg{color:#be123c;font-weight:600}

    .foot{margin-top:10px;font-size:11px;color:var(--muted);line-height:1.4}
    .eq{margin-top:10px;font-size:11px;color:var(--muted);line-height:1.5}
  </style>
</head>

<body>
  <!-- 캡처 대상 전체 영역 -->
  <div class="wrap" id="captureArea">
    <div class="header">
      <div>
        <h1>투자비 감가상각(회수) 계산기</h1>
        <p class="sub">
          신규 부품 대체로 발생하는 <b>원가절감액</b>으로 <b>금형/치공구 투자비</b>를 상계(회수)하는 기간을 계산합니다.
        </p>
      </div>

      <!-- 우측 상단: 만든이 + 버튼 -->
      <div style="display:flex;flex-direction:column;gap:8px;align-items:flex-end;">
        <div class="maker">만든이 : RPI팀 김정우 팀장</div>
        <div style="display:flex;gap:10px;flex-wrap:wrap;justify-content:flex-end;">
          <button class="btn" id="copyBtn" title="요약을 클립보드로 복사">📋 요약 복사</button>
          <button class="btn" id="pptBtn" title="현재 화면 구성 그대로 PPT 1장으로 다운로드">📤 PPT(1장) 내보내기</button>
        </div>
      </div>
    </div>

    <div class="warn" id="warnBox" style="display:none;">
      <strong>체크가 필요한 입력이 있습니다</strong>
      <ul id="warnList"></ul>
    </div>

    <div class="grid-main">
      <!-- INPUT -->
      <section class="card">
        <div class="card-h"><h3 class="card-t">입력</h3></div>
        <div class="card-c">
          <div style="margin-bottom:14px;">
            <label for="investment">투자비(취득원가) (원)</label>
            <input id="investment" inputmode="numeric" placeholder="예: 12,500,000" />
            <div class="help">* 3자리마다 콤마(,)가 자동 표기됩니다.</div>
          </div>

          <div class="row2" style="margin-bottom:14px;">
            <div>
              <label for="oldCost">기존 단가 (원/EA)</label>
              <input id="oldCost" inputmode="decimal" placeholder="예: 77" />
              <div class="help" id="diffLine">차이: - 원/EA | 인하율: -</div>
            </div>
            <div>
              <label for="newCost">신규 단가 (원/EA)</label>
              <input id="newCost" inputmode="decimal" placeholder="예: 64.5" />
            </div>
          </div>

          <div style="margin-bottom:14px;">
            <label for="annualQty">연간 소요량 (EA/년)</label>
            <input id="annualQty" inputmode="numeric" placeholder="예: 1,676,210" />
          </div>

          <hr style="border:none;border-top:1px solid var(--border);margin:16px 0;" />

          <button class="adv-toggle" id="advToggle" type="button">
            <span><b>고급 옵션</b></span>
            <span id="advArrow">▲</span>
          </button>

          <div class="adv show" id="advBox">
            <div class="row2" style="margin-top:12px;">
              <div>
                <label for="monthsPerYear">연간 운영 개월(분모)</label>
                <input id="monthsPerYear" inputmode="numeric" placeholder="기본 12" />
                <div class="help">예: 계절성 제품은 10개월 등으로 조정</div>
              </div>
              <div>
                <label for="extraMonthlyCost">추가 월 고정비(원)</label>
                <input id="extraMonthlyCost" inputmode="numeric" placeholder="예: 0" />
                <div class="help">예: 추가 검사/인건비 등(월 기준)</div>
              </div>
            </div>

            <div class="row2" style="margin-top:12px;">
              <div>
                <label for="rampMonths">초기 안정화 기간(개월)</label>
                <input id="rampMonths" inputmode="numeric" placeholder="예: 2" />
                <div class="help">예: 초기 2~3개월 생산량이 낮은 경우</div>
              </div>
              <div>
                <label for="rampRate">안정화 기간 물량 비율</label>
                <input id="rampRate" inputmode="decimal" placeholder="예: 0.67" />
                <div class="help">예: 2/3 수준이면 0.67</div>
              </div>
            </div>

            <div style="margin-top:12px;">
              <label for="maxSimMonths">최대 시뮬레이션(개월)</label>
              <input id="maxSimMonths" inputmode="numeric" placeholder="예: 120" />
            </div>
          </div>
        </div>
      </section>

      <!-- RESULTS -->
      <section class="card">
        <div class="card-h"><h3 class="card-t">결과 요약</h3></div>
        <div class="card-c">
          <div class="kpis">
            <div class="kpi" id="kpiUnit">
              <div class="t">단위 절감</div>
              <div class="v" id="unitSavingTxt">- 원/EA</div>
              <div class="s" id="unitSubTxt">= 기존 - 신규 | 인하율 -</div>
            </div>
            <div class="kpi" id="kpiQty">
              <div class="t">월 기준 물량</div>
              <div class="v" id="monthlyQtyTxt">- EA</div>
              <div class="s" id="monthlyQtySub">연간물량 ÷ 12개월</div>
            </div>
            <div class="kpi" id="kpiMonth">
              <div class="t">월 순절감</div>
              <div class="v" id="monthlySavingTxt">- 원/월</div>
              <div class="s" id="monthlySavingSub">고정비 0원 가정</div>
            </div>
            <div class="kpi" id="kpiYear">
              <div class="t">연 순절감</div>
              <div class="v" id="annualSavingTxt">- 원/년</div>
              <div class="s" id="annualSavingSub">월 순절감 × 12개월</div>
            </div>
          </div>

          <div class="summary-box">
            <div style="display:flex;gap:8px;flex-wrap:wrap;">
              <span class="pill" id="pillInv">투자비: - 원</span>
              <span class="pill" id="pillBEQ">손익분기 수량: - EA</span>
              <span class="pill" id="pillPayback">회수기간: -</span>
            </div>
            <div class="summary-line"><b>요약:</b> <span id="summaryTxt">-</span></div>
            <div class="muted" id="rampNote" style="display:none;font-size:11px;"></div>
          </div>

          <div class="chart-wrap">
            <div style="font-size:13px;font-weight:600;margin-bottom:8px;">투자비 잔액 추이(월)</div>
            <canvas id="chart" style="width:100%;height:220px;"></canvas>
          </div>
        </div>
      </section>
    </div>

    <!-- TABLE -->
    <section class="card table-card">
      <div class="card-h"><h3 class="card-t">월별 상세(최대 24개월 표시)</h3></div>
      <div class="card-c">
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>월</th>
                <th>물량(EA)</th>
                <th>총 절감액(원)</th>
                <th>추가 고정비(원)</th>
                <th>순 절감액(원)</th>
                <th>누적 절감액(원)</th>
                <th>투자비 잔액(원)</th>
              </tr>
            </thead>
            <tbody id="tbody"></tbody>
          </table>
        </div>

        <div class="eq">
          <b>계산식(요약)</b><br/>
          • 단위절감(원/EA) = 기존단가 - 신규단가<br/>
          • 인하율(%) = (기존-신규) ÷ 기존 × 100<br/>
          • 월 물량(EA) = 연간 소요량 ÷ 연간 운영 개월<br/>
          • 월 총절감액(원) = 단위절감 × 월 물량<br/>
          • 월 순절감액(원) = 월 총절감액 - 추가 월 고정비<br/>
          • 투자비 잔액 = 투자비 - 월 순절감액 누적<br/>
          • 회수기간 = 투자비 잔액이 0 이하가 되는 최초의 월(M)
        </div>

        <div class="foot">
          ⚠️ 참고: 본 도구의 “감가상각”은 회계상 정액/정률 감가상각이 아닌,
          <b>원가절감으로 투자비를 회수(상계)</b>하는 프로젝트 관리 관점의 계산입니다.
        </div>
      </div>
    </section>
  </div>

  <!-- 외부 라이브러리 (CDN) -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <script src="https://cdn.jsdelivr.net/gh/gitbrent/pptxgenjs/dist/pptxgen.bundle.js"></script>

  <script>
    // ====== Formatter ======
    const nf0 = new Intl.NumberFormat("ko-KR", { maximumFractionDigits: 0 });
    const nf2 = new Intl.NumberFormat("ko-KR", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
    const $ = (id) => document.getElementById(id);

    function parseNumber(raw) {
      if (raw === undefined || raw === null) return 0;
      const cleaned = String(raw).replace(/,/g, "").replace(/[^0-9.]/g, "");
      if (cleaned === "" || cleaned === ".") return 0;
      const n = Number(cleaned);
      return Number.isFinite(n) ? n : 0;
    }

    function formatWithCommas(raw) {
      if (raw === undefined || raw === null) return "";
      const s = String(raw);
      const cleaned = s.replace(/[^0-9.]/g, "");
      if (cleaned === "") return "";
      const parts = cleaned.split(".");
      const intPart = parts[0] ? String(parseInt(parts[0], 10)) : "0";
      const decPart = parts.length > 1 ? parts[1].slice(0, 6) : "";
      const intFormatted = nf0.format(Number(intPart || 0));
      return decPart.length ? `${intFormatted}.${decPart}` : intFormatted;
    }

    function clamp(n, min, max) {
      return Math.max(min, Math.min(max, n));
    }

    // ====== Defaults ======
    const inputs = {
      investmentRaw: "12,500,000",
      oldCostRaw: "77",
      newCostRaw: "64.5",
      annualQtyRaw: "1,676,210",
      monthsPerYearRaw: "12",
      rampMonthsRaw: "0",
      rampRateRaw: "0.67",
      maxSimMonthsRaw: "120",
      extraMonthlyCostRaw: "0"
    };

    // ====== Elements ======
    const investmentEl = $("investment");
    const oldCostEl = $("oldCost");
    const newCostEl = $("newCost");
    const annualQtyEl = $("annualQty");
    const monthsPerYearEl = $("monthsPerYear");
    const rampMonthsEl = $("rampMonths");
    const rampRateEl = $("rampRate");
    const maxSimMonthsEl = $("maxSimMonths");
    const extraMonthlyCostEl = $("extraMonthlyCost");

    function setInitial() {
      investmentEl.value = inputs.investmentRaw;
      oldCostEl.value = inputs.oldCostRaw;
      newCostEl.value = inputs.newCostRaw;
      annualQtyEl.value = inputs.annualQtyRaw;
      monthsPerYearEl.value = inputs.monthsPerYearRaw;
      rampMonthsEl.value = inputs.rampMonthsRaw;
      rampRateEl.value = inputs.rampRateRaw;
      maxSimMonthsEl.value = inputs.maxSimMonthsRaw;
      extraMonthlyCostEl.value = inputs.extraMonthlyCostRaw;
    }

    function attachCommaInput(el) {
      el.addEventListener("input", () => {
        const cursorFromEnd = el.value.length - el.selectionStart;
        el.value = formatWithCommas(el.value);
        const newPos = Math.max(0, el.value.length - cursorFromEnd);
        try { el.setSelectionRange(newPos, newPos); } catch {}
        recalc();
      });
    }

    // ====== Advanced toggle ======
    const advToggle = $("advToggle");
    const advBox = $("advBox");
    const advArrow = $("advArrow");
    advToggle.addEventListener("click", () => {
      const show = !advBox.classList.contains("show");
      advBox.classList.toggle("show", show);
      advArrow.textContent = show ? "▲" : "▼";
    });

    // ====== Copy Summary ======
    $("copyBtn").addEventListener("click", async () => {
      const txt = $("summaryTxt").textContent || "";
      try { await navigator.clipboard.writeText(txt); }
      catch { alert("클립보드 복사에 실패했습니다. 브라우저 권한을 확인해주세요."); }
    });

    // ====== Chart ======
    let chart;
    function initChart() {
      const ctx = document.getElementById("chart");
      chart = new Chart(ctx, {
        type: "line",
        data: {
          labels: [],
          datasets: [
            { label: "투자비 잔액(원)", data: [], borderColor: "#0f172a", borderWidth: 2, pointRadius: 0, tension: 0.25 },
            { label: "누적 절감액(원)", data: [], borderColor: "#16a34a", borderWidth: 2, pointRadius: 0, tension: 0.25 }
          ]
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          plugins: {
            tooltip: { callbacks: { label: (c) => `${c.dataset.label}: ${nf0.format(c.raw)}` } },
            legend: { display: true }
          },
          scales: { y: { ticks: { callback: (v) => nf0.format(v) } } }
        }
      });
    }

    // ====== Compute ======
    function recalc() {
      const investment = parseNumber(investmentEl.value);
      const oldCost = parseNumber(oldCostEl.value);
      const newCost = parseNumber(newCostEl.value);
      const annualQty = parseNumber(annualQtyEl.value);

      const monthsPerYear = clamp(parseInt(parseNumber(monthsPerYearEl.value), 10) || 12, 1, 24);
      const rampMonths = clamp(parseInt(parseNumber(rampMonthsEl.value), 10) || 0, 0, 60);
      const rampRate = clamp(parseNumber(rampRateEl.value) || 0, 0, 2);
      const maxSimMonths = clamp(parseInt(parseNumber(maxSimMonthsEl.value), 10) || 120, 1, 600);
      const extraMonthlyCost = parseNumber(extraMonthlyCostEl.value);

      const unitSaving = oldCost - newCost;
      const reductionRate = (oldCost > 0) ? ((oldCost - newCost) / oldCost) * 100 : null;
      const monthlyBaseQty = monthsPerYear ? (annualQty / monthsPerYear) : 0;

      const annualSaving = unitSaving * annualQty - extraMonthlyCost * monthsPerYear;
      const monthlySavingBase = unitSaving * monthlyBaseQty - extraMonthlyCost;

      const warnings = [];
      if (investment <= 0) warnings.push("투자비(취득원가)가 0 이하입니다.");
      if (annualQty <= 0) warnings.push("연간 소요량이 0 이하입니다.");
      if (unitSaving <= 0) warnings.push("단가절감(기존-신규)이 0 이하입니다. (절감이 아니라 인상일 수 있음)");
      if (extraMonthlyCost > 0 && annualSaving <= 0) warnings.push("추가 월 고정비를 반영하면 연간 순절감이 0 이하입니다.");

      // ✅ 그래프 X축 = maxSimMonths (항상 M1~MmaxSimMonths)
      let remaining = investment;
      let cumSaving = 0;
      let breakevenMonth = null;
      const rows = [];

      for (let m = 1; m <= maxSimMonths; m++) {
        const qtyFactor = (rampMonths > 0 && m <= rampMonths) ? rampRate : 1;
        const qty = monthlyBaseQty * qtyFactor;
        const grossSaving = unitSaving * qty;
        const netSaving = grossSaving - extraMonthlyCost;

        cumSaving += netSaving;
        remaining -= netSaving;

        if (breakevenMonth === null && remaining <= 0) breakevenMonth = m;

        rows.push({
          month: m, label: "M" + m,
          qty, grossSaving, extraMonthlyCost, netSaving, cumSaving,
          remaining: Math.max(0, remaining)
        });
      }

      if (breakevenMonth === null && investment > 0 && unitSaving > 0) {
        warnings.push("설정된 최대 시뮬레이션 기간 내에 회수 완료가 되지 않습니다.");
      }

      const paybackMonths = breakevenMonth;
      const paybackYears = paybackMonths ? (paybackMonths / 12) : null;
      const breakEvenQty = unitSaving > 0 ? (investment / unitSaving) : null;

      // 기존 단가 아래
      $("diffLine").textContent =
        `차이: ${nf2.format(unitSaving)} 원/EA | 인하율: ${reductionRate === null ? "-" : nf2.format(reductionRate) + "%"}`;

      // KPI 카드
      const kpiUnit = $("kpiUnit");
      kpiUnit.classList.remove("good","bad");
      kpiUnit.classList.add(unitSaving > 0 ? "good" : "bad");

      $("unitSavingTxt").textContent = `${nf2.format(unitSaving)} 원/EA`;
      $("unitSubTxt").textContent =
        `= 기존 ${nf2.format(oldCost)} - 신규 ${nf2.format(newCost)} | 인하율 ${reductionRate === null ? "-" : nf2.format(reductionRate) + "%"}`;

      $("monthlyQtyTxt").textContent = `${nf0.format(Math.round(monthlyBaseQty))} EA`;
      $("monthlyQtySub").textContent = `연간물량 ÷ ${monthsPerYear}개월`;

      const kpiMonth = $("kpiMonth");
      kpiMonth.classList.remove("good","bad");
      kpiMonth.classList.add(monthlySavingBase > 0 ? "good" : "bad");

      $("monthlySavingTxt").textContent = `${nf0.format(Math.round(monthlySavingBase))} 원/월`;
      $("monthlySavingSub").textContent =
        extraMonthlyCost > 0 ? `고정비 ${nf0.format(extraMonthlyCost)}원/월 반영` : "고정비 0원 가정";

      const kpiYear = $("kpiYear");
      kpiYear.classList.remove("good","bad");
      kpiYear.classList.add(annualSaving > 0 ? "good" : "bad");

      $("annualSavingTxt").textContent = `${nf0.format(Math.round(annualSaving))} 원/년`;
      $("annualSavingSub").textContent = `월 순절감 × ${monthsPerYear}개월`;

      // 요약
      $("pillInv").textContent = `투자비: ${nf0.format(investment)} 원`;
      $("pillBEQ").textContent = `손익분기 수량: ${breakEvenQty ? nf0.format(Math.ceil(breakEvenQty)) + " EA" : "-"}`;
      $("pillPayback").textContent =
        `회수기간: ${paybackMonths ? (paybackMonths + " 개월") : "(미회수)"}${paybackYears ? " (" + nf2.format(paybackYears) + " 년)" : ""}`;

      const rrTxt = (reductionRate === null) ? "-" : nf2.format(reductionRate) + "%";
      const pmTxt = paybackMonths ? paybackMonths + "개월" : "(미회수)";
      const beqTxt = breakEvenQty ? nf0.format(Math.ceil(breakEvenQty)) : "-";
      $("summaryTxt").textContent =
        `투자비 ${nf0.format(investment)}원 / 단위절감 ${nf2.format(unitSaving)}원 (${rrTxt} 인하) / 연간순절감 ${nf0.format(Math.round(annualSaving))}원 → 회수기간 ${pmTxt} (손익분기 수량: ${beqTxt}EA)`;

      // 램프업 노트
      const rampNote = $("rampNote");
      if (rampMonths > 0) {
        rampNote.style.display = "block";
        rampNote.textContent = `* 초기 ${rampMonths}개월은 물량을 ${Math.round(rampRate * 100)}%로 적용했습니다.`;
      } else {
        rampNote.style.display = "none";
      }

      // 경고
      const warnBox = $("warnBox");
      const warnList = $("warnList");
      warnList.innerHTML = "";
      if (warnings.length) {
        warnBox.style.display = "block";
        warnings.forEach(w => {
          const li = document.createElement("li");
          li.textContent = w;
          warnList.appendChild(li);
        });
      } else {
        warnBox.style.display = "none";
      }

      // 테이블(24개월)
      const tbody = $("tbody");
      tbody.innerHTML = "";
      rows.slice(0, 24).forEach(r => {
        const tr = document.createElement("tr");
        tr.innerHTML = `
          <td><b>${r.label}</b></td>
          <td>${nf0.format(Math.round(r.qty))}</td>
          <td>${nf0.format(Math.round(r.grossSaving))}</td>
          <td>${nf0.format(Math.round(r.extraMonthlyCost))}</td>
          <td class="${r.netSaving >= 0 ? "pos" : "neg"}">${nf0.format(Math.round(r.netSaving))}</td>
          <td>${nf0.format(Math.round(r.cumSaving))}</td>
          <td>${nf0.format(Math.round(r.remaining))}</td>
        `;
        tbody.appendChild(tr);
      });

      // 차트 업데이트 (labels 길이 = maxSimMonths)
      if (chart) {
        chart.data.labels = rows.map(r => r.label);
        chart.data.datasets[0].data = rows.map(r => Math.round(r.remaining));
        chart.data.datasets[1].data = rows.map(r => Math.round(r.cumSaving));
        chart.update();
      }
    }

    // ====== PPT Export: 1 slide (화면 동일) ======
    function fitToSlide(imgW, imgH, slideW, slideH){
      const imgRatio = imgW / imgH;
      const slideRatio = slideW / slideH;
      let w, h, x, y;
      if (imgRatio > slideRatio) {
        // 이미지가 더 가로로 김 → 가로 맞추고 세로 중앙정렬
        w = slideW;
        h = slideW / imgRatio;
        x = 0;
        y = (slideH - h) / 2;
      } else {
        // 이미지가 더 세로로 김 → 세로 맞추고 가로 중앙정렬
        h = slideH;
        w = slideH * imgRatio;
        y = 0;
        x = (slideW - w) / 2;
      }
      return {x,y,w,h};
    }

    async function exportPptOneSlide() {
      const btn = $("pptBtn");
      const oldText = btn.textContent;

      try {
        recalc(); // 최신 값 반영

        btn.disabled = true;
        btn.textContent = "⏳ PPT 생성 중...";

        // 캡처 영역
        const el = document.getElementById("captureArea");

        const canvas = await html2canvas(el, {
          backgroundColor: getComputedStyle(document.body).backgroundColor || "#f8fafc",
          scale: 2,
          useCORS: true
        });

        const dataUrl = canvas.toDataURL("image/png", 1.0);

        if (typeof PptxGenJS === "undefined") {
          alert("PPT 라이브러리(PptxGenJS) 로딩 실패: 인터넷 또는 CDN을 확인하세요.");
          return;
        }

        const pptx = new PptxGenJS();
        pptx.layout = "LAYOUT_WIDE"; // 13.33 x 7.5

        const slide = pptx.addSlide();
        slide.background = { color: "FFFFFF" };

        // 이미지 비율 유지해서 슬라이드에 꽉 차게(Contain)
        const slideW = 13.33, slideH = 7.5;
        const pos = fitToSlide(canvas.width, canvas.height, slideW, slideH);

        slide.addImage({
          data: dataUrl,
          x: pos.x, y: pos.y, w: pos.w, h: pos.h
        });

        const now = new Date();
        const y = now.getFullYear();
        const mo = String(now.getMonth() + 1).padStart(2, "0");
        const d = String(now.getDate()).padStart(2, "0");
        const fileName = `투자비회수_화면동일_1장_${y}${mo}${d}.pptx`;

        await pptx.writeFile({ fileName });
      } catch (e) {
        console.error(e);
        alert("PPT 내보내기에 실패했습니다. (콘솔 로그 확인)");
      } finally {
        btn.disabled = false;
        btn.textContent = oldText;
      }
    }

    $("pptBtn").addEventListener("click", exportPptOneSlide);

    // ====== Setup ======
    setInitial();

    attachCommaInput(investmentEl);
    attachCommaInput(oldCostEl);
    attachCommaInput(newCostEl);
    attachCommaInput(annualQtyEl);
    attachCommaInput(monthsPerYearEl);
    attachCommaInput(rampMonthsEl);
    attachCommaInput(rampRateEl);
    attachCommaInput(maxSimMonthsEl);
    attachCommaInput(extraMonthlyCostEl);

    initChart();
    recalc();
  </script>
</body>
